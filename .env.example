# === BASE DE DATOS ===
# Supabase / PostgreSQL local
# pgbouncer=true → requerido para conexiones en runtime (pooled)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"

# URL directa (sin pgbouncer) → requerida para prisma migrate deploy
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# === AUTENTICACIÓN (NextAuth.js) ===
# Generar con: openssl rand -base64 32
NEXTAUTH_SECRET="tu-secreto-muy-seguro-aqui-32-chars"

# En producción: URL pública de tu deploy (ej: https://newsoft-sales.vercel.app)
NEXTAUTH_URL="http://localhost:3000"

# === CONTRASEÑAS INICIALES DE USUARIOS (usadas en seed) ===
# Cambiar antes de correr prisma/seed.ts en producción
ADMIN_PASSWORD="cambiar-en-produccion"
SALES_PASSWORD="cambiar-en-produccion"
