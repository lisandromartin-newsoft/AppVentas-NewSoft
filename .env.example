# ============================================================
# Variables de entorno — Newsoft Sales
# Copiá este archivo a:
#   - .env.local  → para la app (Next.js runtime)
#   - .env        → para la CLI de Prisma (migrate/studio/seed)
# NUNCA commitear .env / .env.local / .env.production (ver .gitignore).
# ============================================================

# === BASE DE DATOS (PostgreSQL) ===
# Local: Postgres en Docker.  Staging/Producción: Postgres gestionado.
# URL usada por el runtime de Prisma (pooled si el proveedor lo ofrece).
POSTGRES_PRISMA_URL="postgresql://USER:PASSWORD@HOST:PORT/newsoft_sales?schema=public"
# URL directa (sin pooling) — usada por `prisma migrate deploy`.
POSTGRES_URL_NON_POOLING="postgresql://USER:PASSWORD@HOST:PORT/newsoft_sales?schema=public"

# === AUTENTICACIÓN ===
# Secreto para firmar el JWT de sesión — generar con: openssl rand -base64 32
SESSION_SECRET="cambiar-por-un-secreto-de-al-menos-32-caracteres"

# === SEED / USUARIOS INICIALES (opcional; defaults en prisma/seed.ts) ===
# ADMIN_PASSWORD="..."
# SALES_PASSWORD="..."

# === ENTORNO ===
NODE_ENV="development"
